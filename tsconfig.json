{
    "compilerOptions": {
        "baseUrl": "./src",
        "typeRoots": [
            "node_modules/@types"
        ],
        "target": "es5",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "checkJs": false
    },
    "noImplicitAny": false,
    "include": [
        "src"
    ],
    "exclude": [
        "../_biong_backend"
    ]
}