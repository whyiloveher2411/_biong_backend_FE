# Copy file này thành .env.cloudflare rồi điền token thật.
# Token tạo tại: Cloudflare Dashboard -> My Profile -> API Tokens
#
# Quyền tối thiểu theo script:
# - Cache Purge + Cache Rules Edit (setup-cache-bypass.sh)
# - WAF Edit (setup-ip-allowlist.sh — khi đổi IP WARP)

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=spacedev.vn
