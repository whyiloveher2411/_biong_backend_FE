FAST_REFRESH=false
PORT=3030

# Public URL của API (dùng cho request /api/admin/*)
REACT_APP_HOST_API_KEY=https://local-api.spacedev.vn

# Public URL gốc để resolve asset local từ API
REACT_APP_BASE_URL=https://local-api.spacedev.vn

# Nếu CMS chạy ở https://cms.yourdomain.com/admin
REACT_APP_BASENAME=admin
